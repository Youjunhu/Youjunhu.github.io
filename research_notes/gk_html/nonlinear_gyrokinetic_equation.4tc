\doTocEntry\tocsection{D}{\csname a:TocLink\endcsname{13}{x13-69000D}{QQ2-13-82}{Coordinate system and grid in \text  {{\ttfamily  {TEK}}} code}}{186}\relax 
\doTocEntry\tocsubsection{D.1}{\csname a:TocLink\endcsname{13}{x13-70000D.1}{QQ2-13-83}{Poloidal grid}}{186}\relax 
\doTocEntry\toclof{11}{\csname a:TocLink\endcsname{13}{x13-7000111}{}{\ignorespaces Poloidal grid for equilibrium quantities used in \text  {{\ttfamily  {TEK}}} and \text  {{\ttfamily  {GEM}}} code. The array starts at $\theta = - \pi $ and ends at $\theta = + \pi $ ($\theta = \pm \pi $ is chosen to be at the high-field side midplane in both the codes). \text  {{\ttfamily  {TEK}}} array index starts from 1 whereas GEM array index starts from $0$. Hence \text  {{\ttfamily  {mpol=nth+1}}}. \text  {{\ttfamily  {nth}}} is denoted by \text  {{\ttfamily  {ntheta}}} in GEM. In \text  {{\ttfamily  {TEK}}}, \text  {{\ttfamily  {mpol}}} must be an odd number, so that the array has a midpoint indexed by \text  {{\ttfamily  {(mpol+1)/2}}}, which corresponds to $\theta = 0$.}}{figure}\relax 
\doTocEntry\tocsubsection{D.2}{\csname a:TocLink\endcsname{13}{x13-71000D.2}{QQ2-13-85}{Toroidal grid}}{189}\relax 
\doTocEntry\toclof{12}{\csname a:TocLink\endcsname{13}{x13-7100112}{}{\ignorespaces Toroidal grid used in \text  {{\ttfamily  {TEK}}} and GEM. In TEK, the toroidal array is \text  {{\ttfamily  {tor\_1d\_array(1:mtor+1)}}}. Source terms, $\delta n$ and $\delta j_{\parallel }$, and EM fields are defined at \text  {{\ttfamily  {1:mtor}}}. GEM array index starts from $0$ and ends at \text  {{\ttfamily  {jm}}}. It follows that \text  {{\ttfamily  {mtor=jm}}}.}}{figure}\relax 
\doTocEntry\tocsubsection{D.3}{\csname a:TocLink\endcsname{13}{x13-72000D.3}{QQ2-13-87}{Radial grid}}{192}\relax 
\doTocEntry\toclof{13}{\csname a:TocLink\endcsname{13}{x13-7200113}{}{\ignorespaces Radial grid used in \text  {{\ttfamily  {TEK}}}. Two radial arrays are used in the code, \text  {{\ttfamily  {radcor\_1d\_array(1:nt)}}} and \text  {{\ttfamily  {radcor\_1d\_array2(1:n)}}}, equilibrium is defined on the former grid, and perturbations are defined on the latter grid. Here $\ensuremath  {\operatorname  {nt}} = n + 2 m$, $m$ is the number of grid points in one of the two buffer regions (regions in blue color). In the code $n$ is denoted by \text  {{\ttfamily  {nflux2}}} and $\ensuremath  {\operatorname  {nt}}$ is denoted by \text  {{\ttfamily  {nflux}}}, $m$ is denoted by \text  {{\ttfamily  {points\_in\_buffer}}}. In \text  {{\ttfamily  {GEM}}} the radial array does no include the buffer regions and the index starts at \text  {{\ttfamily  {0}}} and ends at \text  {{\ttfamily  {imx}}}. Hence \text  {{\ttfamily  {n=imx+1}}}.}}{figure}\relax 
